# Skopiuj ten plik jako backend/.env i uzupelnij wartosci

# --- WYMAGANE ---

# Klucz API do Yahoo Finance via Axesso
AXESSO_API_KEY=tu_wklej_klucz_axesso

# Klucz API OpenAI (do generowania briefow przez LLM)
OPENAI_API_KEY=tu_wklej_klucz_openai

# --- OPCJONALNE (domyslne wartosci dzialaja lokalnie) ---

# Model OpenAI (domyslnie gpt-4.1-mini)
# OPENAI_MODEL=gpt-4.1-mini

# Ile newsow LLM wybiera do briefu
# LLM_TOP_K=5

# Tryb autoryzacji Axesso: auto | direct
# AXESSO_AUTH_MODE=auto

# URL API Axesso
# AXESSO_BASE_URL=https://api.axesso.de/yho

# Naglowek HTTP z kluczem (zalezy od planu Axesso)
# AXESSO_API_KEY_HEADER=axesso-api-key

# Wlacz logi diagnostyczne Axesso
# AXESSO_DEBUG=false

# Baza danych (domyslnie plik lokalny finnews.db)
# DATABASE_URL=sqlite:///./finnews.db

# Sekret JWT (zmien w produkcji)
# JWT_SECRET_KEY=change-me-in-prod
